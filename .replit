modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
JWT_SECRET = "1aaa85ea2b11b9a7b846de28ebef0fb8404a7e93ca57b0f606f126587e32aa17"
ENCRYPTION_KEY = "e89cd651c8033c5fbff141d83a4cdfe2d2660d69a433d3aa24c74c4d479cde82"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 20130
externalPort = 3000

[nix]
channel = "stable-25_05"
